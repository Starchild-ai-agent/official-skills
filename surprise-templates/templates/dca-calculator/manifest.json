{
  "id": "dca-calculator",
  "name": "DCA Calculator",
  "category": "D",
  "matchSignals": ["calculator", "dca", "investment", "strategy", "crypto"],
  "description": "定投计算器：模拟 DCA 策略回测，对比一次性投入，可视化收益曲线与明细表格",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "TRACKED_TOKENS": "追踪的代币列表（逗号分隔）",
