  },
  "apis": [
    {"name": "CoinGecko", "endpoint": "api.coingecko.com/api/v3/coins/{id}/market_chart", "cors": true, "rateLimit": "30/min"}
  ],
  "themes": ["forest-dawn", "warm-sand", "olive-grove"],
  "features": ["dark-mode", "responsive", "charts", "form-validation"],
  "catalogIds": ["D12"]
}
