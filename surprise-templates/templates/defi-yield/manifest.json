{
  "id": "defi-yield",
  "name": "DeFi Yield Optimizer",
  "category": "A",
  "matchSignals": ["wallet", "defi", "yield", "farming", "staking"],
  "description": "为当前持仓推荐最佳收益策略，跨协议 APY 对比",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "TRACKED_TOKENS": "追踪的代币列表（JSON 数组，如 [\"ethereum\",\"usd-coin\",\"tether\"]）",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选，回退到 CSS 渐变）"
  },
  "apis": [
    {"name": "DeFi Llama Yields", "endpoint": "yields.llama.fi/pools", "cors": true},
    {"name": "CoinGecko", "endpoint": "api.coingecko.com/api/v3", "cors": true, "rateLimit": "30/min"}
  ],
  "themes": ["matrix-green", "cyber-neon", "electric-blue"],
  "features": ["dark-mode", "responsive", "charts", "sortable-table"],
  "catalogIds": ["A4"]
}
