{
  "id": "dependency-monitor",
  "name": "Dependency Update Monitor",
  "category": "B",
  "matchSignals": ["github", "dependencies", "security", "updates", "npm"],
  "description": "依赖健康监控仪表盘：版本更新追踪、安全漏洞检测、生态系统分布、更新频率分析",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "GITHUB_USERNAME": "GitHub 用户名（用于获取公开仓库信息）",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选，回退到 CSS 渐变）"
  },
  "apis": [
    {"name": "GitHub API", "endpoint": "api.github.com", "cors": true, "rateLimit": "60/hr (unauthenticated)"}
  ],
  "themes": ["midnight-gold", "deep-space", "matrix-green"],
  "features": ["dark-mode", "responsive", "charts", "dependency-tracking", "security-audit"],
  "catalogIds": ["B3"]
}
