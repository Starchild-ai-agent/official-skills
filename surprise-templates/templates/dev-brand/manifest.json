{
  "id": "dev-brand",
  "name": "Developer Brand Page",
  "category": "E",
  "matchSignals": ["github", "twitter", "brand", "portfolio", "developer"],
  "description": "开发者品牌页：全宽个人展示、项目网格、技术栈、社交影响力、联系方式",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "GITHUB_USERNAME": "GitHub 用户名",
    "TWITTER_HANDLE": "Twitter/X 用户名",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选，回退到 CSS 渐变）"
  },
  "apis": [
    {"name": "GitHub API", "endpoint": "api.github.com/users/{username}", "cors": true, "rateLimit": "60/hr"}
  ],
  "themes": ["warm-ember", "midnight-gold", "clean-slate"],
  "features": ["dark-mode", "responsive", "api-integration", "portfolio"],
  "catalogIds": ["E3"]
}
