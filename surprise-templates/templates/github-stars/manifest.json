{
  "id": "github-stars",
  "name": "GitHub Stars Explorer",
  "category": "B",
  "matchSignals": ["github", "stars", "repositories", "analysis", "interests"],
  "description": "GitHub Stars 探索器：分析你的 starred 仓库，发现语言分布、兴趣模式、热门项目与标签云",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "GITHUB_USERNAME": "GitHub 用户名",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选，回退到 CSS 渐变）"
  },
  "apis": [
    {"name": "GitHub API", "endpoint": "api.github.com/users/{username}/starred", "cors": true, "rateLimit": "60/hr (unauthenticated)"}
  ],
  "themes": ["cyber-neon", "deep-space", "electric-blue"],
  "features": ["dark-mode", "responsive", "charts", "real-time-updates"],
  "catalogIds": ["B15"]
}
