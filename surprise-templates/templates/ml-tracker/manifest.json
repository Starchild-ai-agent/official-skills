{
  "id": "ml-tracker",
  "name": "ML Experiment Tracker",
  "category": "E",
  "matchSignals": ["github", "twitter", "ml", "experiment", "python"],
  "description": "ML 实验追踪器：实验表格、训练曲线、模型对比、论文推荐",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "GITHUB_USERNAME": "GitHub 用户名",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选，回退到 CSS 渐变）"
  },
  "apis": [
    {"name": "GitHub API", "endpoint": "api.github.com", "cors": true, "rateLimit": "60/hr"}
  ],
  "themes": ["deep-space", "matrix-green", "cyber-neon"],
  "features": ["dark-mode", "responsive", "charts", "table-sort"],
  "catalogIds": ["E11"]
}
