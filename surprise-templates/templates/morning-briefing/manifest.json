{
  "id": "morning-briefing",
  "name": "Morning Intelligence Briefing",
  "category": "D",
  "matchSignals": ["news", "briefing", "morning", "daily", "summary", "update", "digest"],
  "description": "个性化早间简报：市场概览、热门新闻、天气、日历提醒、每日名言",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "INTERESTS": "用户兴趣领域（JSON 数组，如 [\"crypto\",\"tech\",\"finance\"]）",
    "CITY": "用户所在城市（如 \"Shanghai\"）",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选）"
  },
  "apis": [
    {"name": "CoinGecko", "endpoint": "api.coingecko.com/api/v3", "cors": true, "rateLimit": "30/min"},
    {"name": "HackerNews", "endpoint": "hacker-news.firebaseio.com/v0", "cors": true},
    {"name": "Quotable", "endpoint": "api.quotable.io", "cors": true}
  ],
  "themes": ["sunset-gradient", "arctic-frost", "lavender-dream", "paper-ink", "forest-canopy"],
  "features": ["light-mode-default", "responsive", "time-based-greeting"],
  "catalogIds": ["D1"]
}
