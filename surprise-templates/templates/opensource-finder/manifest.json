{
  "id": "opensource-finder",
  "name": "Open Source Opportunity Finder",
  "category": "B",
  "matchSignals": ["github", "opensource", "contribution", "good-first-issue", "community"],
  "description": "开源贡献机会发现器：Good First Issues 搜索、语言分布、热门仓库推荐、贡献难度评估",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "GITHUB_USERNAME": "GitHub 用户名",
    "TECH_STACK": "技术栈（逗号分隔，如 javascript,python,rust）",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选，回退到 CSS 渐变）"
  },
  "apis": [
    {"name": "GitHub API", "endpoint": "api.github.com", "cors": true, "rateLimit": "60/hr (unauthenticated)"}
  ],
  "themes": ["midnight-gold", "cyber-neon", "matrix-green"],
  "features": ["dark-mode", "responsive", "charts", "github-search", "issue-discovery"],
  "catalogIds": ["B5"]
}
