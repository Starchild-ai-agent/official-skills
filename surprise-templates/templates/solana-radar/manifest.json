{
  "id": "solana-radar",
  "name": "Solana Ecosystem Radar",
  "category": "E",
  "matchSignals": ["wallet", "twitter", "solana", "ecosystem", "defi"],
  "description": "Solana 生态雷达：SOL 价格、DApp 排行、生态代币、NFT 市场、DEX 交易量、网络健康",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "WALLET_ADDRESS": "钱包地址（可选）",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选，回退到 CSS 渐变）"
  },
  "apis": [
    {"name": "CoinGecko", "endpoint": "api.coingecko.com/api/v3", "cors": true, "rateLimit": "30/min"},
    {"name": "Built-in Solana Ecosystem Data", "endpoint": "mock", "cors": true}
  ],
  "themes": ["matrix-green", "deep-space", "cyber-neon"],
  "features": ["dark-mode", "responsive", "charts", "full-bleed-hero", "theme-toggle"],
  "catalogIds": ["E10"]
}
