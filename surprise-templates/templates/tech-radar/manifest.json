{
  "id": "tech-radar",
  "name": "Tech Stack Trend Radar",
  "category": "B",
  "matchSignals": ["github", "developer", "programming", "code", "tech", "stack", "framework"],
  "description": "技术栈趋势雷达：GitHub 热门仓库、技术趋势、开发者新闻聚合",
  "placeholders": {
    "APP_TITLE": "应用标题（如 'Dev Radar'）",
    "USER_NAME": "用户名",
    "TECH_STACK": "用户技术栈（JSON 数组，如 [\"typescript\",\"react\",\"python\"]）",
    "GITHUB_USERNAME": "GitHub 用户名（可选）",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选）"
  },
  "apis": [
    {"name": "GitHub Trending (unofficial)", "endpoint": "api.gitterapp.com", "cors": true},
    {"name": "HackerNews", "endpoint": "hacker-news.firebaseio.com/v0", "cors": true},
    {"name": "GitHub API", "endpoint": "api.github.com", "cors": true, "rateLimit": "60/hour"}
  ],
  "themes": ["paper-ink", "industrial-steel", "monochrome-noir", "forest-canopy", "arctic-frost"],
  "features": ["light-mode-default", "responsive", "editorial-layout", "keyboard-shortcuts"],
  "catalogIds": ["B1", "B2"]
}
