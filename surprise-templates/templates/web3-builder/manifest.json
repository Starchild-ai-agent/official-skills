{
  "id": "web3-builder",
  "name": "Web3 Builder Dashboard",
  "category": "E",
  "matchSignals": ["github", "wallet", "web3", "builder", "developer"],
  "description": "Web3 构建者仪表盘：GitHub 技术栈 + 链上活动 + 生态机会 + 技能雷达",
  "placeholders": {
    "APP_TITLE": "应用标题",
    "USER_NAME": "用户名",
    "GITHUB_USERNAME": "GitHub 用户名",
    "WALLET_ADDRESS": "钱包地址（0x...）",
    "HERO_IMAGE_URL": "主视觉图片 URL（可选，回退到 CSS 渐变）"
  },
  "apis": [
    {"name": "GitHub API", "endpoint": "api.github.com/users/{username}", "cors": true, "rateLimit": "60/hr"},
    {"name": "CoinGecko", "endpoint": "api.coingecko.com/api/v3", "cors": true, "rateLimit": "30/min"}
  ],
  "themes": ["matrix-green", "deep-space", "cyber-neon"],
  "features": ["dark-mode", "responsive", "charts", "api-integration"],
  "catalogIds": ["E1"]
}
